generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// MULTI-TENANT & PLANS
// ============================================

model Plan {
  id        String   @id @default(uuid())
  name      String
  price     Decimal  @db.Decimal(10, 2)
  maxUsers  Int      @map("max_users")
  maxTables Int      @map("max_tables")
  features  Json // Array de features habilitadas
  active    Boolean  @default(true)
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  establishments Establishment[]

  @@map("plans")
}

model Establishment {
  id                    String              @id @default(uuid())
  name                  String
  cnpj                  String?             @unique
  email                 String
  phone                 String?
  address               Json? // Endereço completo
  logo                  String? // Logo da empresa
  planId                String              @map("plan_id")
  status                EstablishmentStatus @default(ACTIVE)
  subscriptionExpiresAt DateTime?           @map("subscription_expires_at")
  settings              Json? // Configurações personalizadas
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")

  plan           Plan            @relation(fields: [planId], references: [id])
  users          User[]
  tables         Table[]
  categories     Category[]
  products       Product[]
  ingredients    Ingredient[]
  comandas       Comanda[]
  orders         Order[]
  stockMovements StockMovement[]

  @@index([planId])
  @@map("establishments")
}

enum EstablishmentStatus {
  ACTIVE
  SUSPENDED
  CANCELLED
  TRIAL
}

// ============================================
// USERS & AUTH
// ============================================

model User {
  id              String   @id @default(uuid())
  establishmentId String   @map("establishment_id")
  name            String
  email           String
  password        String
  role            UserRole
  active          Boolean  @default(true)
  avatar          String?
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  establishment  Establishment   @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  orders         Order[]
  stockMovements StockMovement[]
  orderHistory   OrderHistory[]

  @@unique([establishmentId, email])
  @@index([establishmentId])
  @@map("users")
}

enum UserRole {
  ADMIN
  WAITER
  KITCHEN
  CASHIER
}

// ============================================
// TABLES & COMANDAS
// ============================================

model Table {
  id              String      @id @default(uuid())
  establishmentId String      @map("establishment_id")
  number          String
  capacity        Int         @default(4)
  status          TableStatus @default(AVAILABLE)
  positionX       Float?      @map("position_x") // Para mapa visual
  positionY       Float?      @map("position_y")
  createdAt       DateTime    @default(now()) @map("created_at")
  updatedAt       DateTime    @updatedAt @map("updated_at")

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  comandas      Comanda[]

  @@unique([establishmentId, number])
  @@index([establishmentId])
  @@map("tables")
}

enum TableStatus {
  AVAILABLE
  OCCUPIED
  RESERVED
  CLEANING
}

model Comanda {
  id              String        @id @default(uuid())
  establishmentId String        @map("establishment_id")
  tableId         String?       @map("table_id")
  customerName    String?       @map("customer_name")
  status          ComandaStatus @default(OPEN)
  openedAt        DateTime      @default(now()) @map("opened_at")
  closedAt        DateTime?     @map("closed_at")
  total           Decimal       @default(0) @db.Decimal(10, 2)
  createdAt       DateTime      @default(now()) @map("created_at")
  updatedAt       DateTime      @updatedAt @map("updated_at")

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  table         Table?        @relation(fields: [tableId], references: [id], onDelete: SetNull)
  orders        Order[]
  payments      Payment[]

  @@index([establishmentId])
  @@index([tableId])
  @@index([status, tableId])
  @@map("comandas")
}

enum ComandaStatus {
  OPEN
  CLOSED
  PAID
  CANCELLED
}

// ============================================
// PRODUCTS & CATEGORIES
// ============================================

model Category {
  id              String   @id @default(uuid())
  establishmentId String   @map("establishment_id")
  name            String
  icon            String?
  order           Int      @default(0)
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  products      Product[]

  @@index([establishmentId])
  @@map("categories")
}

model Product {
  id              String  @id @default(uuid())
  establishmentId String  @map("establishment_id")
  categoryId      String  @map("category_id")
  name            String
  description     String?
  price           Decimal @db.Decimal(10, 2)
  image           String?
  code            String? // Código interno (ex: 101)
  preparationTime Int?    @map("preparation_time") // Em minutos
  active          Boolean @default(true)

  // Controle de estoque direto (para produtos prontos: cerveja, água, etc)
  stockControl  Boolean  @default(false) @map("stock_control") // Se controla estoque direto
  stockQuantity Decimal? @default(0) @map("stock_quantity") @db.Decimal(10, 2) // Quantidade em estoque
  stockUnit     String?  @map("stock_unit") // unidade, caixa, litro, etc
  minStock      Decimal? @map("min_stock") @db.Decimal(10, 2) // Estoque mínimo

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  establishment Establishment       @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  category      Category            @relation(fields: [categoryId], references: [id])
  ingredients   ProductIngredient[]
  orderItems    OrderItem[]

  @@index([establishmentId])
  @@index([categoryId])
  @@map("products")
}

model Ingredient {
  id              String   @id @default(uuid())
  establishmentId String   @map("establishment_id")
  name            String
  unit            String // unidade (kg, L, unidade)
  ingredientType  String   @default("OUTRO") @map("ingredient_type") // ALIMENTO, BEBIDA, OUTRO
  minStock        Decimal  @map("min_stock") @db.Decimal(10, 2)
  currentStock    Decimal  @map("current_stock") @db.Decimal(10, 2)
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  establishment Establishment       @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  products      ProductIngredient[]
  movements     StockMovement[]

  @@index([establishmentId])
  @@map("ingredients")
}

model ProductIngredient {
  productId    String  @map("product_id")
  ingredientId String  @map("ingredient_id")
  quantity     Decimal @db.Decimal(10, 3) // Quantidade usada por produto

  product    Product    @relation(fields: [productId], references: [id], onDelete: Cascade)
  ingredient Ingredient @relation(fields: [ingredientId], references: [id], onDelete: Cascade)

  @@id([productId, ingredientId])
  @@map("product_ingredients")
}

model StockMovement {
  id              String       @id @default(uuid())
  establishmentId String       @map("establishment_id")
  ingredientId    String       @map("ingredient_id")
  userId          String?      @map("user_id")
  type            MovementType
  quantity        Decimal      @db.Decimal(10, 2)
  reason          String?
  createdAt       DateTime     @default(now()) @map("created_at")

  establishment Establishment @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  ingredient    Ingredient    @relation(fields: [ingredientId], references: [id])
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([establishmentId])
  @@index([ingredientId])
  @@index([createdAt])
  @@map("stock_movements")
}

enum MovementType {
  IN // Entrada
  OUT // Saída
  ADJUSTMENT // Ajuste
  WASTE // Desperdício
}

// ============================================
// ORDERS
// ============================================

model Order {
  id              String      @id @default(uuid())
  establishmentId String      @map("establishment_id")
  comandaId       String      @map("comanda_id")
  userId          String      @map("user_id")
  status          OrderStatus @default(PENDING)
  observations    String?
  createdAt       DateTime    @default(now()) @map("created_at")
  preparedAt      DateTime?   @map("prepared_at")
  deliveredAt     DateTime?   @map("delivered_at")

  establishment Establishment  @relation(fields: [establishmentId], references: [id], onDelete: Cascade)
  comanda       Comanda        @relation(fields: [comandaId], references: [id], onDelete: Cascade)
  user          User           @relation(fields: [userId], references: [id])
  items         OrderItem[]
  history       OrderHistory[]

  @@index([establishmentId])
  @@index([comandaId])
  @@index([status])
  @@index([status, createdAt])
  @@map("orders")
}

enum OrderStatus {
  PENDING // Aguardando
  PREPARING // Em preparo
  READY // Pronto
  DELIVERED // Entregue
  CANCELLED // Cancelado
}

model OrderItem {
  id           String      @id @default(uuid())
  orderId      String      @map("order_id")
  productId    String      @map("product_id")
  quantity     Int
  price        Decimal     @db.Decimal(10, 2)
  observations String?
  status       OrderStatus @default(PENDING)

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
  @@map("order_items")
}

model OrderHistory {
  id        String      @id @default(uuid())
  orderId   String      @map("order_id")
  userId    String?     @map("user_id")
  oldStatus OrderStatus @map("old_status")
  newStatus OrderStatus @map("new_status")
  changedAt DateTime    @default(now()) @map("changed_at")

  order Order @relation(fields: [orderId], references: [id], onDelete: Cascade)
  user  User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([orderId])
  @@map("order_history")
}

// ============================================
// PAYMENTS
// ============================================

model Payment {
  id            String        @id @default(uuid())
  comandaId     String        @map("comanda_id")
  amount        Decimal       @db.Decimal(10, 2)
  method        PaymentMethod
  status        PaymentStatus @default(PENDING)
  transactionId String?       @map("transaction_id")
  createdAt     DateTime      @default(now()) @map("created_at")
  paidAt        DateTime?     @map("paid_at")

  comanda Comanda @relation(fields: [comandaId], references: [id], onDelete: Cascade)

  @@index([comandaId])
  @@index([status])
  @@map("payments")
}

enum PaymentMethod {
  CASH
  CREDIT_CARD
  DEBIT_CARD
  PIX
  VOUCHER
}

enum PaymentStatus {
  PENDING
  PAID
  CANCELLED
  REFUNDED
}
