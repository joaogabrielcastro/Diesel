# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/diesel_bar?schema=public"

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production
JWT_EXPIRES_IN=7d

# Server
PORT=3000
NODE_ENV=development

# CORS
# Multiple origins separated by comma (no spaces)
# Production: add your Vercel/production domain
CORS_ORIGIN=http://localhost:5173,https://diesel-web.vercel.app

# File Upload
MAX_FILE_SIZE=5242880

# Printer
PRINTER_ENABLED=false
PRINTER_IP=192.168.1.100
PRINTER_PORT=9100
